<script>
// ── CURSOR ──
const cur = document.getElementById('cur');
let cx=0,cy=0,tx=200,ty=200;
document.addEventListener('mousemove',e=>{tx=e.clientX;ty=e.clientY;});
(function loop(){cx+=(tx-cx)*.2;cy+=(ty-cy)*.2;cur.style.transform=`translate(${cx-6}px,${cy-6}px)`;requestAnimationFrame(loop);})();
document.addEventListener('mousedown',()=>{cur.classList.add('cut');playSnip();});
document.addEventListener('mouseup',()=>cur.classList.remove('cut'));

// ── PROGRESS + SCROLL ──
const prog=document.getElementById('prog'),navbar=document.getElementById('navbar');
window.addEventListener('scroll',()=>{
  prog.style.width=(window.scrollY/(document.body.scrollHeight-innerHeight)*100)+'%';
  navbar.classList.toggle('down',window.scrollY>50);
},{passive:true});

// ── REVEAL ──
const ro=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');playPop();}});},{threshold:0.1});
document.querySelectorAll('.rv,.rl,.rr').forEach(el=>ro.observe(el));

// ── SOUND ──
let ac=null;
function gac(){if(!ac)ac=new(window.AudioContext||window.webkitAudioContext)();return ac;}
function tone(f,d,type='sine',vol=0.1,delay=0){try{const a=gac(),o=a.createOscillator(),g=a.createGain();o.connect(g);g.connect(a.destination);o.type=type;o.frequency.value=f;const t=a.currentTime+delay;g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(vol,t+.01);g.gain.exponentialRampToValueAtTime(.0001,t+d);o.start(t);o.stop(t+d);}catch(e){}}
let lastPop=0;
function playPop(){const n=Date.now();if(n-lastPop<280)return;lastPop=n;tone(500+Math.random()*250,.11,'sine',.07);}
function playSnip(){tone(2000,.04,'sawtooth',.06);tone(2600,.035,'sawtooth',.05,.03);}
function playHover(){tone(800,.06,'sine',.05);}
function playCoupon(){[392,494,587,740,988].forEach((f,i)=>tone(f,.18,'sine',.09,i*.08));}
function playSuccess(){[523,659,784,988,1319].forEach((f,i)=>tone(f,.22,'sine',.1,i*.09));}
document.querySelectorAll('.svc,.cp,.cs,.nb,.wcard').forEach(el=>el.addEventListener('mouseenter',playHover));
document.querySelectorAll('.cpn-btn').forEach(el=>el.addEventListener('mouseenter',playCoupon));

// ── COUPON JIGGLE ──
const cpnEl=document.getElementById('cpn');
const cpnObs=new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    setTimeout(()=>{cpnEl.animate([{transform:'rotate(0) scale(1)'},{transform:'rotate(-1.5deg) scale(1.03)'},{transform:'rotate(1.8deg) scale(1.04)'},{transform:'rotate(-1.2deg) scale(1.03)'},{transform:'rotate(0) scale(1)'}],{duration:420,easing:'ease-in-out'});playCoupon();},350);
    cpnObs.disconnect();
  }
},{threshold:0.55});
cpnObs.observe(cpnEl);

// ── BOOKING with Formspree ──
const FORMSPREE_ID = 'xyklwdqb'; // ← Replace with your Formspree form ID

async function handleBook(e){
  e.preventDefault();
  const btn = document.getElementById('bbtn');
  const form = document.getElementById('bookingForm');
  btn.textContent = 'Sending…';
  btn.disabled = true;

  try {
    const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    });
    if (res.ok) {
      btn.textContent = '✅  Got it! We will call you today.';
      btn.style.background = 'rgba(255,255,255,0.2)';
      btn.style.border = '1.5px solid rgba(255,255,255,0.5)';
      form.reset();
      playSuccess();
      confettiBurst();
    } else {
      btn.textContent = '❌ Something went wrong. Please call us!';
      btn.style.background = '#c0392b';
      btn.disabled = false;
    }
  } catch(err) {
    btn.textContent = '❌ Network error. Please call us directly!';
    btn.style.background = '#c0392b';
    btn.disabled = false;
  }
}

// ── CONFETTI ──
function confettiBurst(){
  const cols=['#b8860b','#2d6e2d','#4a9a4a','#f0b429','#ffffff','#d4a017'];
  for(let i=0;i<70;i++){
    const el=document.createElement('div');
    const s=5+Math.random()*9,isCircle=Math.random()>.45;
    el.style.cssText=`position:fixed;z-index:9997;pointer-events:none;width:${s}px;height:${s}px;border-radius:${isCircle?'50%':'2px'};background:${cols[Math.floor(Math.random()*cols.length)]};left:${20+Math.random()*60}vw;top:${40+Math.random()*25}vh;opacity:1;`;
    document.body.appendChild(el);
    const dx=(Math.random()-.5)*300,dy=-(80+Math.random()*200),rot=(Math.random()-.5)*720;
    el.animate([{transform:`translate(0,0) rotate(0deg)`,opacity:1},{transform:`translate(${dx}px,${dy}px) rotate(${rot}deg)`,opacity:0}],{duration:900+Math.random()*700,easing:'cubic-bezier(.22,1,.36,1)',fill:'forwards'});
    setTimeout(()=>el.remove(),2000);
  }
}


if(innerWidth<640) document.getElementById('bgWrap').style.display='none';
</script>
