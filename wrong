<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --green:#1a4a1a;--green-mid:#2d6e2d;--green-light:#4a9a4a;--green-pale:#edf7ed;
  --gold:#b8860b;--gold-light:#d4a017;--gold-bright:#f0b429;
  --cream:#f8f8f4;--white:#ffffff;--charcoal:#1c1c1c;--text:#2a2a2a;--muted:#6b7280;--border:#e5e7eb;
}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;cursor:none;}
#cur{position:fixed;z-index:9999;pointer-events:none;top:0;left:0;will-change:transform;}
#cur svg{width:40px;height:40px;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.28));}
#cur.cut .blade-top{transform-origin:22px 20px;transform:rotate(18deg);transition:transform .08s;}
#cur.cut .blade-bot{transform-origin:22px 20px;transform:rotate(-18deg);transition:transform .08s;}
.blade-top,.blade-bot{transition:transform .12s;}
#prog{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--green),var(--gold-bright));z-index:201;width:0;transition:width .08s;}
.bg-wrap{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
.bg-img{position:absolute;border-radius:18px;opacity:0;transition:opacity 1.4s ease;box-shadow:0 12px 48px rgba(0,0,0,0.14);background-size:cover;background-position:center;}
.bg-img.show{opacity:1;}
.bi1{width:420px;height:280px;top:7%;left:-60px;transform:rotate(-4deg);}
.bi2{width:320px;height:220px;top:50%;left:-50px;transform:rotate(2.5deg);}
.bi3{width:400px;height:270px;top:10%;right:-55px;transform:rotate(3.5deg);}
.bi4{width:310px;height:210px;bottom:8%;right:-45px;transform:rotate(-2deg);}
.bg-fade{position:fixed;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse 55% 90% at 50% 50%,rgba(248,248,244,0.94) 20%,rgba(248,248,244,0.6) 65%,transparent 100%),linear-gradient(90deg,rgba(248,248,244,0.88) 0%,transparent 22%,transparent 78%,rgba(248,248,244,0.88) 100%);}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 52px;background:rgba(248,248,244,0.88);backdrop-filter:blur(18px);border-bottom:1px solid transparent;transition:all .35s;}
nav.down{padding:12px 52px;border-color:rgba(0,0,0,0.07);box-shadow:0 2px 24px rgba(0,0,0,0.07);}
.logo{font-family:'DM Serif Display',serif;font-size:21px;color:var(--green);display:flex;align-items:center;gap:9px;}
.nav-r{display:flex;align-items:center;gap:22px;}
.nl{font-size:14px;font-weight:500;color:var(--muted);text-decoration:none;transition:color .2s;}
.nl:hover{color:var(--green);}
.nb{background:var(--green);color:#fff;padding:10px 26px;border-radius:100px;font-size:14px;font-weight:600;text-decoration:none;box-shadow:0 2px 14px rgba(26,74,26,0.22);transition:all .22s;}
.nb:hover{background:var(--green-mid);transform:translateY(-1px);}
.rv{opacity:0;transform:translateY(30px);transition:opacity .72s cubic-bezier(.22,1,.36,1),transform .72s cubic-bezier(.22,1,.36,1);}
.rv.on{opacity:1;transform:translateY(0);}
.rl{opacity:0;transform:translateX(-28px);transition:opacity .72s cubic-bezier(.22,1,.36,1),transform .72s cubic-bezier(.22,1,.36,1);}
.rl.on{opacity:1;transform:translateX(0);}
.rr{opacity:0;transform:translateX(28px);transition:opacity .72s cubic-bezier(.22,1,.36,1),transform .72s cubic-bezier(.22,1,.36,1);}
.rr.on{opacity:1;transform:translateX(0);}
.hero{position:relative;z-index:2;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;}
.badge{display:inline-flex;align-items:center;gap:6px;background:var(--green-pale);border:1px solid rgba(26,74,26,0.15);color:var(--green);font-size:13px;font-weight:600;letter-spacing:.04em;padding:6px 20px;border-radius:100px;margin-bottom:28px;}
h1.hero-h{font-family:'DM Serif Display',serif;font-size:clamp(54px,9.5vw,120px);line-height:.96;color:var(--green);margin-bottom:22px;}
h1.hero-h em{font-style:italic;color:var(--gold);}
.hero-p{font-size:clamp(16px,2vw,20px);color:var(--muted);max-width:460px;line-height:1.68;margin-bottom:44px;}
.ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.cp{background:var(--green);color:#fff;padding:16px 44px;border-radius:100px;font-size:16px;font-weight:600;text-decoration:none;box-shadow:0 4px 22px rgba(26,74,26,0.28);transition:all .22s;}
.cp:hover{background:var(--green-mid);transform:translateY(-2px);}
.cs{background:#fff;color:var(--green);padding:16px 44px;border-radius:100px;font-size:16px;font-weight:600;text-decoration:none;border:1.5px solid rgba(26,74,26,0.18);transition:all .22s;}
.cs:hover{border-color:var(--green);background:var(--green-pale);}
.stars-r{display:flex;align-items:center;gap:7px;justify-content:center;margin-top:38px;}
.stars{color:var(--gold-bright);font-size:19px;letter-spacing:1px;}
.stars-t{font-size:14px;color:var(--muted);}
.trust{position:relative;z-index:2;background:var(--green);padding:20px 52px;display:flex;align-items:center;justify-content:center;gap:44px;flex-wrap:wrap;}
.ti{display:flex;align-items:center;gap:7px;color:rgba(255,255,255,0.9);font-size:14px;font-weight:500;}
.sec{position:relative;z-index:2;padding:96px 52px;}
.si{max-width:1060px;margin:0 auto;}
.eyebrow{font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green-light);margin-bottom:12px;}
.sec-h{font-family:'DM Serif Display',serif;font-size:clamp(34px,5vw,58px);color:var(--green);line-height:1.08;margin-bottom:14px;}
.sec-p{font-size:17px;color:var(--muted);line-height:1.72;max-width:500px;}
.divider{width:48px;height:3px;background:var(--gold);margin:20px 0;border-radius:2px;}
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:14px;margin-top:52px;}
.svc{background:#fff;border-radius:16px;padding:30px 26px;border:1px solid var(--border);transition:transform .26s,box-shadow .26s,border-color .26s;}
.svc:hover{transform:translateY(-5px);box-shadow:0 14px 44px rgba(0,0,0,0.09);border-color:rgba(26,74,26,0.18);}
.svc-ico{width:50px;height:50px;background:var(--green-pale);border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:23px;margin-bottom:16px;}
.svc h3{font-family:'DM Serif Display',serif;font-size:19px;color:var(--charcoal);margin-bottom:7px;}
.svc p{font-size:14px;color:var(--muted);line-height:1.6;}
.svc-pr{margin-top:15px;font-size:14px;font-weight:600;color:var(--green-light);}
.wgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:52px;}
@media(max-width:580px){.wgrid{grid-template-columns:1fr;}}
.wcard{border-radius:16px;overflow:hidden;position:relative;box-shadow:0 4px 22px rgba(0,0,0,0.09);}
.wimg{width:100%;aspect-ratio:4/3;display:block;background-size:cover;background-position:center;transition:filter .4s,transform .45s;filter:saturate(0.88) brightness(0.94);}
.wcard:hover .wimg{filter:saturate(1.05) brightness(1);transform:scale(1.04);}
.wlabel{position:absolute;bottom:14px;left:14px;background:rgba(255,255,255,0.92);backdrop-filter:blur(8px);padding:5px 14px;border-radius:100px;font-size:13px;font-weight:600;color:var(--green);}
.cpn-wrap{display:flex;justify-content:center;padding-top:8px;}
.cpn{position:relative;background:#fff;border:2.5px dashed var(--gold);border-radius:22px;padding:44px 60px;text-align:center;max-width:500px;width:100%;box-shadow:0 10px 48px rgba(184,134,11,0.13);overflow:hidden;transition:transform .2s,box-shadow .2s;}
.cpn:hover{transform:scale(1.015);box-shadow:0 16px 60px rgba(184,134,11,0.22);}
.cpn-scissors{position:absolute;top:13px;right:16px;font-size:14px;color:var(--gold);font-weight:700;letter-spacing:.1em;}
.cpn-tag{display:inline-block;background:var(--green);color:#fff;font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;padding:4px 16px;border-radius:100px;margin-bottom:16px;}
.cpn-title{font-family:'DM Serif Display',serif;font-size:22px;color:var(--charcoal);margin-bottom:22px;}
.prow{display:flex;align-items:center;justify-content:center;gap:22px;}
.op{font-family:'DM Serif Display',serif;font-size:52px;color:#bbb;position:relative;line-height:1;}
.op::after{content:'';position:absolute;top:50%;left:-6px;right:-6px;height:3.5px;background:var(--muted);transform:translateY(-50%) rotate(-6deg);border-radius:2px;}
.np{font-family:'DM Serif Display',serif;font-size:80px;color:var(--green);line-height:1;}
.np sup{font-size:30px;vertical-align:top;margin-top:14px;display:inline-block;}
.cpn-sub{font-size:14px;color:var(--muted);margin-top:16px;line-height:1.65;}
.cpn-btn{display:inline-block;margin-top:26px;background:var(--gold);color:#fff;padding:14px 40px;border-radius:100px;font-size:15px;font-weight:700;text-decoration:none;transition:all .2s;box-shadow:0 4px 22px rgba(184,134,11,0.32);}
.cpn-btn:hover{background:var(--gold-bright);transform:scale(1.05);}
.dot{position:absolute;border-radius:50%;opacity:.22;}
#booking{background:var(--green);}
#booking .eyebrow{color:rgba(255,255,255,0.55);}
#booking .sec-h{color:#fff;}
#booking .sec-p{color:rgba(255,255,255,0.65);}
#booking .divider{background:var(--gold-bright);}
.binner{max-width:640px;margin:0 auto;}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:48px;}
@media(max-width:500px){.fgrid{grid-template-columns:1fr;}}
.fl{display:flex;flex-direction:column;gap:5px;}
.fl label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.55);}
.fl input,.fl select,.fl textarea{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);color:#fff;padding:13px 16px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;outline:none;transition:border-color .2s,background .2s;}
.fl input::placeholder,.fl textarea::placeholder{color:rgba(255,255,255,0.38);}
.fl input:focus,.fl select:focus,.fl textarea:focus{border-color:var(--gold-bright);background:rgba(255,255,255,0.15);}
.fl select option{background:#1a4a1a;}
.fl-full{grid-column:1/-1;}
.fl textarea{height:108px;resize:none;}
.bbtn{grid-column:1/-1;background:var(--gold);color:#fff;padding:18px;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:17px;font-weight:700;border:none;cursor:pointer;transition:all .22s;box-shadow:0 4px 22px rgba(184,134,11,0.38);position:relative;overflow:hidden;}
.bbtn:hover{background:var(--gold-bright);transform:translateY(-2px);}
footer{position:relative;z-index:2;background:var(--charcoal);color:rgba(255,255,255,0.45);padding:30px 52px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;font-size:13px;}
.flogo{font-family:'DM Serif Display',serif;font-size:18px;color:#fff;}
@media(max-width:640px){nav{padding:13px 18px;}.nav-r .nl{display:none;}.sec{padding:64px 18px;}#booking{padding:64px 18px 64px;}.trust{gap:20px;padding:16px 20px;}.cpn{padding:32px 28px;}}
/* SCROLL TRACKS */
.scroll-track-wrap,.rev-track-wrap{overflow:hidden;width:100%;}
.scroll-track{display:flex;gap:16px;width:max-content;animation:scrollLeft 32s linear infinite;}
.scroll-track:hover{animation-play-state:paused;}
.rev-track{display:flex;gap:20px;width:max-content;animation:scrollLeft 48s linear infinite;}
.rev-track:hover{animation-play-state:paused;}
@keyframes scrollLeft{0%{transform:translateX(0);}100%{transform:translateX(-50%)}}
.scroll-item{flex-shrink:0;width:180px;text-align:center;}
.scroll-img{width:180px;height:140px;border-radius:16px;display:block;object-fit:cover;margin-bottom:10px;transition:transform .3s;}
.scroll-item:hover .scroll-img{transform:scale(1.04);}
.scroll-cap{font-size:14px;font-weight:600;color:var(--charcoal);}
/* REVIEW CARDS */
.rev-card{flex-shrink:0;width:320px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);border-radius:18px;padding:26px 24px;backdrop-filter:blur(8px);}
.rev-stars{color:var(--gold-bright);font-size:16px;letter-spacing:2px;margin-bottom:12px;}
.rev-text{font-size:14px;color:rgba(255,255,255,0.88);line-height:1.7;margin-bottom:18px;font-style:italic;}
.rev-author{display:flex;align-items:center;gap:11px;}
.rev-av{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;}
.rev-author strong{display:block;font-size:14px;color:#fff;font-weight:600;}
.rev-author span{font-size:12px;color:rgba(255,255,255,0.55);}
</style>
